{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,
    "isolatedModules": true,

    "skipLibCheck": true
  }
}